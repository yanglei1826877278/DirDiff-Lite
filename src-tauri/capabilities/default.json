{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "opener:default"
    ,
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir"
  ]
}
